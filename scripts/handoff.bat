@echo off
cd /d E:\xsc\app
node -e "const d=require('./src/data/calendarData.json');const fs=require('fs');const batches=[];for(let i=1;i<=10;i++){try{batches.push(require('./scripts/high-quality-examples-batch'+i+'.cjs').highQualityExamples)}catch(e){}}const c=new Set();batches.forEach(b=>Object.keys(b).forEach(k=>c.add(k)));const m={};for(const k of Object.keys(d).sort()){if(k==='9a'||k==='9b')continue;for(const day of d[k].days){for(const w of day.words){if(!w.posDetails)continue;if(c.has(w.word))continue;m[w.word]=(m[w.word]||0)+w.posDetails.length;}}}const s=Object.entries(m).sort((a,b)=>b[1]-a[1]);console.log('========================================');console.log('  高质量例句项目 - 对接状态');console.log('========================================');console.log('已覆盖词: '+c.size);console.log('未覆盖词: '+s.length);console.log('未覆盖例句: '+s.reduce((a,[,b])=>a+b,0));console.log('\n--- 下一批 Top 40 目标词 ---');for(let i=0;i<40&&i<s.length;i++)console.log(String(i+1).padStart(3)+'. '+s[i][0].padEnd(18)+String(s[i][1]).padStart(3)+'条');console.log('\n--- 文件清单 ---');console.log('批次文件:');for(let i=1;i<=batches.length;i++)console.log('  high-quality-examples-batch'+i+'.cjs');console.log('合并脚本: apply-high-quality-all.cjs');console.log('========================================');"
